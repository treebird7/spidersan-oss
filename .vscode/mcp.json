{
  "servers": {
    "spidersan-local": {
      "enabled": true,
      "command": "node",
      "args": ["${env:SPIDERSAN_HOME}/mcp-server/dist/server.js"],
      "env": {
        "SPIDERSAN_HOME": "${workspaceFolder}"
      }
    },
    "toak": {
      "enabled": true,
      "command": "bash",
      "args": ["${env:SPIDERSAN_HOME}/scripts/toak-mcp-wrapper.sh"],
      "env": {
        "TOAK_AGENT_ID": "ssan",
        "SPIDERSAN_HOME": "${workspaceFolder}"
      }
    },
    "envoak": {
      "enabled": true,
      "command": "bash",
      "args": ["${env:SPIDERSAN_HOME}/scripts/envoak-mcp-wrapper.sh"],
      "env": {
        "SPIDERSAN_HOME": "${workspaceFolder}"
      }
    }
  }
}
