# Spidersan Environment Configuration
# Copy this to .env and fill in your values

# Current environment: production, staging, or local
SPIDERSAN_ENV=production

# ── Supabase (cross-machine registry sync) ──────────────────────────────────
# Optional. Without these, Spidersan uses a local JSON registry (.spidersan/).
# Set them to sync branch state to Supabase so machines/agents see each other.
#
# The fleet injects these from a secrets vault (envoak) at run time; if vault-set,
# those win and this file is ignored. Standalone/public users set them HERE — .env
# is gitignored; NEVER commit real keys.
#
# SUPABASE_KEY: for registry-sync WRITES use the project's **service_role** key.
#   The hardened RLS denies anon writes, and reads require an agent JWT, so a
#   service_role key is the trusted-writer credential. ⚠️ service_role BYPASSES RLS
#   (full DB access) — keep it secret, never commit, scope to machines you trust.
#   Read-only/anon will be denied by the hardened policies.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key

# Optional per-environment overrides (SPIDERSAN_ENV selects which is used):
SUPABASE_URL_PROD=https://your-production-project.supabase.co
SUPABASE_KEY_PROD=your_production_service_role_key
SUPABASE_URL_STAGING=https://your-staging-project.supabase.co
SUPABASE_KEY_STAGING=your_staging_service_role_key

# Agent Identity (used in spidermail from/to fields)
# Examples: spidersan-agent, claude-code, cursor, windsurf
SPIDERSAN_AGENT=spidersan-agent

# Treebird Hub URL (for --hub-sync and chat integration)
HUB_URL=https://hub.treebird.uk
